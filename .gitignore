# Environment files
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
# Permitir explícitamente plantillas .env.*.example (son docs, no secretos)
!.env.*.example
!**/.env.*.example

# Node / Next.js
node_modules/
**/node_modules/
.next/
**/.next/
out/
**/out/
dist/
**/dist/
.turbo/
**/.turbo/
.vercel/
**/.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Go build outputs and caches
bin/
**/bin/
*.exe
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html
vendor/
**/vendor/
# Binarios compilados del backend (build outputs sin extensión).
# El proyecto no usa convención *.exe porque target es Linux/Mac;
# sin esta regla el binario 'backend/api' quedaba trackeado.
backend/api
api
**/backend/api
**/api

# Tooling caches
.cache/
**/.cache/
.pytest_cache/
tmp/
**/tmp/

# IDE / editor files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# OS / logs
.DS_Store
Thumbs.db
*.log
