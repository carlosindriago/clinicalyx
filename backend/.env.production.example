# =============================================================================
# Clinicalyx — Ejemplo de variables de entorno para PRODUCCIÓN
# =============================================================================
# ADVERTENCIA: ESTE ARCHIVO ES SOLO UNA PLANTILLA DOCUMENTAL.
#
# NO contiene secretos reales. Cualquier valor placeholder aquí
# (ej. <INSERTE_AQUI_...>) es rechazado por el arranque de la
# aplicación gracias a la validación Fail-Fast en config.Validate().
#
# Para producción real:
#   1. Copie este archivo a un destino seguro FUERA del repositorio
#      (ej. /etc/clinicalyx.env, AWS Secrets Manager, Vault, etc.)
#   2. Reemplace cada <INSERTE_AQUI_...> con un valor criptográficamente
#      aleatorio. Use: openssl rand -hex 32 (para claves de 64 chars)
#                     openssl rand -base64 48 (para sales y secretos)
#   3. NUNCA commitee el archivo con valores reales al repositorio.
#
# El .gitignore del proyecto excluye todos los .env* por seguridad.
# =============================================================================

# Puerto HTTP del servidor
PORT=8080

# Entorno de ejecución (production | staging | development)
ENV=production

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# -----------------------------------------------------------------------------
# Conexión usada por la aplicación con el rol de menor privilegio
# (clinicalyx_app_user). sslmode=require en producción real.
DATABASE_URL=postgres://clinicalyx_app_user:<INSERTE_AQUI_PASSWORD_APP_USER>@postgres:5432/clinicalyx?sslmode=disable

# Conexión administrativa usada SOLO para aplicar migraciones.
# El entrypoint.sh la usa para crear/actualizar el esquema y el rol.
MIGRATIONS_DATABASE_URL=postgres://postgres:<INSERTE_AQUI_PASSWORD_POSTGRES>@postgres:5432/clinicalyx?sslmode=disable

# Password que el entrypoint asigna al rol clinicalyx_app_user al arrancar.
# Debe coincidir con la del DATABASE_URL de aplicación.
CLINICALYX_APP_USER_PASSWORD=<INSERTE_AQUI_PASSWORD_APP_USER>

# -----------------------------------------------------------------------------
# Secretos criptográficos — TODOS rejected por Fail-Fast si contienen
# los marcadores <INSERTE_AQUI> o change_me
# -----------------------------------------------------------------------------

# Clave AES-256-GCM que cifra los campos sensibles (notas clínicas,
# emails, documentos). Mínimo 32 caracteres, idealmente 64 hex chars
# generados con `openssl rand -hex 32`.
ENCRYPTION_KEY=<INSERTE_AQUI_CLAVE_AES_256_GCM_32_BYTES_MIN>

# Salt HMAC-SHA256 usado para los blind indexes (búsqueda exacta
# sobre email/documento sin revelar el valor en claro). Mínimo 32
# chars aleatorios.
BLIND_INDEX_SALT=<INSERTE_AQUI_SALT_HMAC_32_CHARS_MIN>

# Secreto de firma HMAC-SHA256 para los JWT de sesión. Mínimo 32
# chars, idealmente 64 hex chars de `openssl rand -hex 32`.
JWT_SECRET=<INSERTE_AQUI_SECRETO_JWT_32_CHARS_MIN>

# -----------------------------------------------------------------------------
# Sesión / autenticación
# -----------------------------------------------------------------------------

# Duración de los access tokens en minutos (15 recomendado)
JWT_ACCESS_DURATION_MINUTES=15

# Duración de los refresh tokens en días
JWT_REFRESH_DURATION_DAYS=7

# Token de un solo uso para el endpoint POST /api/v1/auth/setup que
# crea el primer SUPERADMIN de un tenant. Si está VACÍO, el endpoint
# queda cerrado. Si está seteado, mínimo 32 chars aleatorios.
# Rotar y re-desplegar después de cada bootstrap de tenant.
SETUP_TOKEN=<INSERTE_AQUI_SETUP_TOKEN_O_VACIO_PARA_DESHABILITAR>

# -----------------------------------------------------------------------------
# CORS / Demo
# -----------------------------------------------------------------------------

# Orígenes permitidos separados por coma. NUNCA usar "*" con credenciales.
CORS_ALLOWED_ORIGINS=https://<INSERTE_AQUI_DOMINIO_FRONTEND>

# Kill switch del modo demo efímero. Mantener false en producción.
ENABLE_EPHEMERAL_DEMO=false

# -----------------------------------------------------------------------------
# Rate limiting / proxies
# -----------------------------------------------------------------------------

# Lista separada por comas de IPs/CIDRs de proxies confiables
# (ej. 10.0.0.0/8,192.168.1.1) que tienen permiso para fijar
# X-Forwarded-For / X-Real-IP. Si está VACÍA, el rate limiter usa
# siempre RemoteAddr (modo seguro por defecto).
TRUSTED_PROXIES_IPS=<INSERTE_AQUI_CIDRS_PROXIES_O_VACIO>

# -----------------------------------------------------------------------------
# Almacenamiento S3 / MinIO
# -----------------------------------------------------------------------------

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<INSERTE_AQUI_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<INSERTE_AQUI_SECRET_ACCESS_KEY>
AWS_BUCKET=clinicalyx-files
AWS_ENDPOINT=https://<INSERTE_AQUI_ENDPOINT_S3_O_MINIO>
