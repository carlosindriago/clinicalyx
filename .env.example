# Servidor HTTP
PORT=8080
ENV=development

# Base de Datos (PostgreSQL)
# Formato: postgres://username:password@host:port/database_name?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/clinicalyx?sslmode=disable

# Seguridad y Cifrado (AES-256-GCM y Blind Index)
# ENCRYPTION_KEY debe ser un hash hexadecimal de 32 bytes (64 caracteres hexadecimales)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BLIND_INDEX_SALT=super_secret_blind_index_salt_for_hmac

# Autenticación (JWT)
JWT_SECRET=super_secret_jwt_signing_key_change_in_production
JWT_ACCESS_DURATION_MINUTES=15
JWT_REFRESH_DURATION_DAYS=7
