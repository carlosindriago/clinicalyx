# Servidor HTTP
PORT=8080
ENV=development

# Local PostgreSQL used by docker compose.
# These are development placeholders only. Do not reuse them in production.
POSTGRES_USER=clinicalyx
POSTGRES_PASSWORD=clinicalyx_dev_password
POSTGRES_DB=clinicalyx

# Application database connection.
# Format: postgres://username:password@host:port/database_name?sslmode=disable
DATABASE_URL=postgres://clinicalyx_app_user:clinicalyx_app_dev_password@localhost:5432/clinicalyx?sslmode=disable

# Seguridad y Cifrado (AES-256-GCM y Blind Index)
# ENCRYPTION_KEY must be exactly 32 bytes for AES-256.
ENCRYPTION_KEY=change_me_32_byte_encryption_key
BLIND_INDEX_SALT=change_me_32_plus_chars_blind_index_salt

# Autenticación (JWT)
JWT_SECRET=change_me_32_plus_chars_jwt_signing_secret
JWT_ACCESS_DURATION_MINUTES=15
JWT_REFRESH_DURATION_DAYS=7

# HTTP / CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# AWS S3 / MinIO (Almacenamiento de archivos médicos)
AWS_ACCESS_KEY_ID=clinicalyx_admin
AWS_SECRET_ACCESS_KEY=clinicalyx_secret
AWS_REGION=us-east-1
AWS_BUCKET=clinicalyx-files
AWS_ENDPOINT=http://localhost:9000

# MinIO Configuration (for docker-compose services)
MINIO_ROOT_USER=clinicalyx_admin
MINIO_ROOT_PASSWORD=clinicalyx_secret
MINIO_BUCKET_NAME=clinicalyx-files
